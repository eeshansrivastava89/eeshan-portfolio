---
import BaseHead from '@/components/BaseHead.astro'
import ThemeProvider from '@/components/ThemeProvider.astro'
import Sidebar from '@/components/Sidebar.astro'
import WritingList from '@/components/WritingList.astro'
import ProjectGrid from '@/components/ProjectGrid.astro'
import ContributionCalendar from '@/components/ContributionCalendar.astro'
import ActivityTimeline from '@/components/ActivityTimeline.astro'
import AboutRecognition from '@/components/AboutRecognition.astro'
import PageNav from '@/components/PageNav.astro'

import { Icon } from 'astro-icon/components'
import { siteConfig } from '@/site-config'

// Load projects
import { getLiveProjects, getProjectsByStatus } from '@/lib/projects'
import { getAllProjects } from '@/data/projectLoader'

// Load Substack posts
import { getSubstackPosts } from '@/lib/substack'
import substackMappingsRaw from '@/data/substack-posts.yaml?raw'

// Load analysis data
import { getAllAnalysisContent } from '@/lib/analysis'

// Load GitHub data
import { getGitHubData } from '@/lib/github'

const SUBSTACK_RSS_URL = 'https://theasymptotic.substack.com/feed'
const allSubstackPosts = await getSubstackPosts(SUBSTACK_RSS_URL, substackMappingsRaw)

const allProjects = getAllProjects()
const liveProjects = getLiveProjects(allProjects)
const inProgressProjects = getProjectsByStatus(allProjects, 'in-progress')
const activeProjects = [...liveProjects, ...inProgressProjects]

// Featured project = first live project (A/B Simulator)
const featuredProject = liveProjects[0]

// Analysis data (notebooks only, top 5)
const allAnalysis = await getAllAnalysisContent(SUBSTACK_RSS_URL, substackMappingsRaw)
const recentAnalysis = allAnalysis.filter(item => item.type === 'notebook').slice(0, 5)

// GitHub data (build-time, cached fallback)
const githubData = await getGitHubData()
---

<html lang={siteConfig.lang} class='scroll-smooth'>
	<head>
		<BaseHead title='Home' description={siteConfig.description} />
	</head>

	<body>
		<ThemeProvider />
		<div class='homepage'>
			<Sidebar />

			<main class='homepage-main'>
				<PageNav />

				<!-- Intro -->
				<p class='homepage-intro'>
					I build and write about AI, data science & privacy to see what will hold up beyond the hype cycles.
					<strong>Everything is open source and transparent.</strong>
				</p>

				<!-- Writing -->
				<section id='writing' class='homepage-section'>
					<div class='section-header'>
						<h1>Writing</h1>
						<div class='section-line'></div>
					</div>
					<WritingList posts={allSubstackPosts} />
				</section>

				<!-- Projects -->
				<section id='projects' class='homepage-section'>
					<div class='section-header'>
						<h1>Projects</h1>
						<div class='section-line'></div>
					</div>
					<ProjectGrid projects={activeProjects} featured={featuredProject} />
					<a class='view-all-link' href='/projects'>View all projects →</a>
				</section>

				<!-- Open Source -->
				<section id='opensource' class='homepage-section'>
					<div class='section-header'>
						<h1>Open Source</h1>
						<div class='section-line'></div>
						<a class='gh-link' href='https://github.com/eeshansrivastava89' target='_blank' rel='noopener noreferrer'>
							<Icon name='simple-icons:github' class='gh-icon' />
							<span>@eeshansrivastava89</span>
						</a>
					</div>

					{githubData && githubData.weeks && githubData.weeks.length > 0 ? (
						<>
								<ContributionCalendar
									weeks={githubData.weeks}
									totalContributions={githubData.totalContributions}
								/>
								<ActivityTimeline activities={githubData.recentActivity} totals={githubData.activityTotals} />
							</>
						) : (
						<p class='homepage-placeholder'>
							GitHub data unavailable — will populate on next build with GITHUB_TOKEN.
						</p>
					)}</section>

				<!-- Analysis -->
				<section id='analysis' class='homepage-section'>
					<div class='section-header'>
						<h1>Published Analysis</h1>
						<div class='section-line'></div>
					</div>
					{recentAnalysis.length > 0 ? (
						<div class='analysis-list'>
							{recentAnalysis.map(item => (
								<a href={item.link} class='analysis-card'>
									<div class='analysis-card-info'>
										<h3 class='analysis-card-title'>{item.title}</h3>
										{item.description && (
											<p class='analysis-card-desc'>{item.description}</p>
										)}
									</div>
									<span class='analysis-card-meta'>
										{item.projectId || 'Analysis'}
									</span>
								</a>
							))}
						</div>
					) : (
						<p class='homepage-placeholder'>
							No published analysis yet.
						</p>
					)}
					<a class='view-all-link' href='/analysis'>View all analysis →</a>
				</section>

				<!-- About & Recognition -->
				<AboutRecognition />

				<!-- Footer -->
				<footer class='homepage-footer'>
					<p class='homepage-quote'>"Just someone who likes making things work, learning by doing, and working with smart people."</p>
					<span class='homepage-location'>Seattle, WA</span>
				</footer>
			</main>
		</div>
	</body>
</html>

<style is:global>
	.homepage {
		display: grid;
		grid-template-columns: 300px 1fr;
		min-height: 100vh;
		max-width: 1280px;
		margin: 0 auto;
		font-family: 'Inter', -apple-system, sans-serif;
		font-size: 14px;
		-webkit-font-smoothing: antialiased;
	}

	.homepage-main {
		padding: 48px 48px 80px 48px;
		max-width: 800px;
	}

	.homepage-intro {
		font-size: 15px;
		color: hsl(var(--muted-foreground));
		line-height: 1.7;
		margin-bottom: 40px;
		max-width: 560px;
	}

	.homepage-intro strong {
		color: hsl(var(--foreground));
		font-weight: 500;
	}

	.homepage-section {
		margin-bottom: 56px;
	}

	.section-header {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 24px;
	}

	.section-header h1,
	.section-header h2 {
		font-family: 'Playfair Display', serif;
		font-size: 26px;
		font-weight: 600;
		white-space: nowrap;
		color: hsl(var(--foreground));
	}

	.section-line {
		flex: 1;
		height: 1px;
		background: hsl(var(--border));
	}

	.gh-link {
		display: flex;
		align-items: center;
		gap: 4px;
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		color: hsl(var(--muted-foreground));
		text-decoration: none;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.gh-link:hover {
		color: hsl(var(--foreground));
	}

	.gh-icon {
		width: 14px;
		height: 14px;
	}

	.analysis-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.analysis-card {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 16px;
		padding: 12px 14px;
		background: hsl(var(--muted));
		border: 1px solid hsl(var(--border));
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		transition: all 0.15s;
	}

	.analysis-card:hover {
		border-color: hsl(var(--foreground) / 0.2);
		transform: translateY(-1px);
	}

	.analysis-card-title {
		font-size: 14px;
		font-weight: 500;
		color: hsl(var(--foreground));
		margin-bottom: 2px;
	}

	.analysis-card-desc {
		font-size: 12px;
		color: hsl(var(--muted-foreground));
		line-height: 1.4;
	}

	.analysis-card-meta {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		color: hsl(var(--muted-foreground));
		white-space: nowrap;
		flex-shrink: 0;
	}

	.view-all-link {
		display: inline-block;
		margin-top: 16px;
		font-size: 13px;
		color: hsl(var(--muted-foreground));
		text-decoration: none;
		font-weight: 450;
	}

	.view-all-link:hover {
		color: hsl(var(--foreground));
	}

	.homepage-placeholder {
		font-size: 13px;
		color: hsl(var(--muted-foreground));
		padding: 24px;
		border: 1px dashed hsl(var(--border));
		border-radius: 8px;
		text-align: center;
	}

	.homepage-footer {
		padding: 32px 0;
		border-top: 1px solid hsl(var(--border));
		font-size: 12px;
		color: hsl(var(--muted-foreground));
		display: flex;
		justify-content: space-between;
		gap: 12px;
	}

	@media (max-width: 600px) {
		.homepage-footer {
			flex-direction: column;
		}
	}

	.homepage-quote {
		font-style: italic;
		max-width: 400px;
	}

	.homepage-location {
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
	}

	@media (max-width: 900px) {
		.homepage {
			grid-template-columns: 1fr;
		}
		.homepage-main {
			padding: 32px 24px 64px;
		}
	}
</style>
