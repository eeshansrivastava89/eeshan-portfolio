---
import BaseHead from '@/components/BaseHead.astro'
import { siteConfig } from '@/site-config'

import { getAllProjects } from '@/data/projectLoader'
import { getLiveProjects } from '@/lib/projects'
import { getAllAnalysisContent, type AnalysisContent } from '@/lib/analysis'
import substackMappingsRaw from '@/data/substack-posts.yaml?raw'

const allProjects = getAllProjects()
const liveProjects = getLiveProjects(allProjects)
const allContent = await getAllAnalysisContent(siteConfig.substackRssUrl, substackMappingsRaw)

const fallbackPosts: AnalysisContent[] = [
	{
		type: 'post',
		title: 'Agentic Coding for Non-Vibe Coders',
		projectId: undefined,
		date: new Date('2026-03-07T00:00:00Z'),
		link: 'https://theasymptotic.substack.com',
		description:
			'A workflow for building real things with AI coding agents without giving up engineering judgment.'
	},
	{
		type: 'post',
		title: 'The Dopamine Trap of AI Coding',
		projectId: undefined,
		date: new Date('2026-02-23T00:00:00Z'),
		link: 'https://theasymptotic.substack.com',
		description:
			'Why AI acceleration is useful, but not if it replaces the discipline of solving hard problems.'
	},
	{
		type: 'post',
		title: "Local AI matters, but it's not ready yet",
		projectId: 'local-llm-bench',
		date: new Date('2026-01-25T00:00:00Z'),
		link: 'https://theasymptotic.substack.com',
		description:
			'What local models get right, where they fail, and why privacy alone is not enough.'
	},
	{
		type: 'post',
		title: 'What 4,887 AI prompts say about how we talk to machines',
		projectId: 'how-i-prompt',
		date: new Date('2026-01-02T00:00:00Z'),
		link: 'https://theasymptotic.substack.com',
		description:
			'Patterns from a year of Claude conversations and what they reveal about human-model interaction.'
	},
	{
		type: 'post',
		title: 'From game design to p-values: Anatomy of a real A/B experiment',
		projectId: 'ab-simulator',
		date: new Date('2025-12-21T00:00:00Z'),
		link: 'https://theasymptotic.substack.com/p/building-an-ab-testing-memory-game',
		description:
			'Most data scientists inherit a pipeline. This project built one end-to-end and made the results public.'
	}
]

const posts = allContent.filter((item) => item.type === 'post')
const notebookItems = allContent.filter((item) => item.type === 'notebook')
const displayPosts = (posts.length > 0 ? posts : fallbackPosts).sort(
	(a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
)
const featuredPost = displayPosts[0]
const recentPosts = displayPosts.slice(1, 5)

const featuredProject = liveProjects.find((project) => project.id === 'ab-simulator') || liveProjects[0]
const secondaryProjects = liveProjects.filter((project) => project.id !== featuredProject?.id)

const projectStats: Record<
	string,
	Array<{ label: string; value: string }>
> = {
	'ab-simulator': [
		{ label: 'sessions played', value: '2,847' },
		{ label: 'completion rate', value: '68.3%' },
		{ label: 'published analyses', value: '4' },
		{ label: 'Substack article', value: '1' }
	],
	'how-i-prompt': [{ label: 'prompts analyzed', value: '4,887' }],
	'local-llm-bench': [{ label: 'models tested', value: '12' }]
}

const conceptProjects = [
	...secondaryProjects,
	{
		id: 'sidequests',
		name: 'Sidequests',
		url: '#',
		status: 'in-progress',
		description:
			'Track all your side projects in one place. Health, commit status, AI summaries, and a cleaner operating view of personal work.',
		shortDescription: 'Track all your side projects in one place',
		tags: [{ name: 'TypeScript' }, { name: 'Supabase' }]
	},
	{
		id: 'quizzard',
		name: 'Quizzard',
		url: '#',
		status: 'live',
		description:
			'Real-time quiz app for live events. A free, self-hosted Kahoot or Mentimeter alternative built with Supabase.',
		shortDescription: 'Real-time quiz app for live events',
		tags: [{ name: 'TypeScript' }, { name: 'Supabase' }]
	}
]

const conceptAnalysis = notebookItems.length
	? notebookItems.slice(0, 4)
	: [
			{
				type: 'notebook' as const,
				title: 'Player Behavior & Completion Rates by Variant',
				projectId: 'ab-simulator',
				date: new Date('2026-03-01T00:00:00Z'),
				link: '/projects/ab-simulator/analysis/ab-test-analysis/',
				description: 'Jupyter notebook'
			},
			{
				type: 'notebook' as const,
				title: 'Time-to-Complete Distribution & Funnel Analysis',
				projectId: 'ab-simulator',
				date: new Date('2026-02-01T00:00:00Z'),
				link: '/projects/ab-simulator/analysis/ab-test-analysis/',
				description: 'Jupyter notebook'
			},
			{
				type: 'notebook' as const,
				title: 'Statistical Significance Testing: Chi-squared & Proportions',
				projectId: 'ab-simulator',
				date: new Date('2026-01-10T00:00:00Z'),
				link: '/projects/ab-simulator/analysis/ab-test-analysis/',
				description: 'Jupyter notebook'
			},
			{
				type: 'notebook' as const,
				title: 'Prompting Patterns Across 4,887 Claude Conversations',
				projectId: 'how-i-prompt',
				date: new Date('2026-01-02T00:00:00Z'),
				link: '#',
				description: 'Python analysis'
			}
		]

const recognitionItems = [
	{ type: 'Award', detail: '5 Under 35 — Weatherhead School of Management', year: '2024' },
	{ type: 'Conference', detail: 'Speaker — ODSC West', year: '2024' },
	{ type: 'Conference', detail: 'Speaker — Data Council', year: '2023' },
	{ type: 'Media', detail: 'What Really Matters Podcast — Weatherhead School', year: '2022' },
	{ type: 'Publication', detail: 'Towards Data Science — Technical articles on Medium', year: '2021–22' },
	{ type: 'Mentorship', detail: '10+ mentored — guest instruction and industry mentoring', year: 'Ongoing' }
]

const recentCommits = [
	{ repo: 'datascienceapps', msg: 'rebrand Substack from 0→1 Data Science to Asymptotic', time: '1w ago' },
	{ repo: 'datascienceapps', msg: 'add Local LLM Bench project', time: '1w ago' },
	{ repo: 'sidequests', msg: 'dashboard layout and project health scoring', time: '2w ago' },
	{ repo: 'local-llm-bench', msg: 'add MLX backend support and F1 scoring', time: '3w ago' },
	{ repo: 'howiprompt', msg: 'persona classification and wrapped report', time: '1mo ago' }
]

function formatLongDate(value: Date | string): string {
	return new Date(value).toLocaleDateString('en-US', {
		month: 'short',
		day: 'numeric',
		year: 'numeric'
	})
}

function formatShortDate(value: Date | string): string {
	return new Date(value).toLocaleDateString('en-US', {
		month: 'short',
		day: 'numeric'
	})
}

function projectHref(projectId?: string): string {
	if (!projectId) return '/analysis'
	return `/analysis?project=${encodeURIComponent(projectId)}`
}

function repoHref(projectId: string): string {
	const base = 'https://github.com/eeshansrivastava89'
	if (projectId === 'ab-simulator') return `${base}/datascienceapps/tree/main/packages/ab-simulator`
	if (projectId === 'how-i-prompt') return `${base}/howiprompt`
	if (projectId === 'local-llm-bench') return `${base}/local-llm-bench`
	if (projectId === 'sidequests') return `${base}/sidequests`
	if (projectId === 'quizzard') return `${base}/quizzard`
	return base
}

function statusLabel(status: string): string {
	if (status === 'in-progress') return 'Building'
	if (status === 'live') return 'Live'
	return status
}
---

<html lang={siteConfig.lang}>
	<head>
		<BaseHead
			title='Hub Mockup v2'
			description='Concept mock-up for a denser eeshans.com homepage that unifies writing, projects, code, and analysis.'
		/>
		<link rel='preconnect' href='https://fonts.googleapis.com' />
		<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
		<link
			href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap'
			rel='stylesheet'
		/>
	</head>
	<body class='hub-v2-body'>
		<div class='mockup-banner'>Mockup v2 — Not Live</div>

		<div class='page-shell'>
			<aside class='sidebar'>
				<div class='identity'>
					<h1>Eeshan Srivastava</h1>
					<div class='role'>
						<strong>Sr. Data Science Manager</strong> at Starbucks<br />
						AI/ML, experimentation, recommendation systems for 40M+ users
					</div>
					<div class='social-row'>
						<a href='https://github.com/eeshansrivastava89' target='_blank' rel='noopener noreferrer'>GitHub</a>
						<a href='https://www.linkedin.com/in/eeshans/' target='_blank' rel='noopener noreferrer'>LinkedIn</a>
						<a href='https://x.com/eeshans' target='_blank' rel='noopener noreferrer'>X</a>
						<a href='/rss.xml'>RSS</a>
					</div>
				</div>

				<nav class='sidebar-nav'>
					<a href='#writing' class='active'>Writing</a>
					<a href='#projects'>Projects</a>
					<a href='#github'>Open Source</a>
					<a href='#analysis'>Analysis</a>
					<a href='#recognition'>Recognition</a>
				</nav>

				<div class='credentials'>
					<div class='section-label'>Experience</div>
					<div class='credential-row'>
						<span class='company'>Starbucks <span class='title'>— Sr. Manager, Data Science</span></span>
						<span class='years'>2019–now</span>
					</div>
					<div class='credential-row'>
						<span class='company'>Overstock <span class='title'>— Manager, Analytics</span></span>
						<span class='years'>2016–19</span>
					</div>
					<div class='credential-row'>
						<span class='company'>Amazon <span class='title'>— Sr. PM Intern</span></span>
						<span class='years'>2015</span>
					</div>
					<div class='credential-row compact-line'>
						<span class='company tertiary'>MIT/EdX · Case Western · GGSIPU</span>
					</div>
				</div>

				<div class='currently'>
					<div class='section-label'>Currently</div>
					<div class='currently-item'>
						<span class='emoji'>✍</span>
						<span class='text'>Writing about <a href='https://theasymptotic.substack.com' target='_blank' rel='noopener noreferrer'>agentic coding workflows</a></span>
					</div>
					<div class='currently-item'>
						<span class='emoji'>🛠</span>
						<span class='text'>Building <a href='#projects'>Sidequests</a> — side project tracker</span>
					</div>
					<div class='currently-item'>
						<span class='emoji'>📚</span>
						<span class='text'>MIT MicroMasters in Statistics</span>
					</div>
				</div>

				<div class='newsletter-box'>
					<div class='name'>Asymptotic</div>
					<div class='desc'>Pragmatic takes on AI, data science, and privacy. Past the hype cycles.</div>
					<a class='subscribe-btn' href='https://theasymptotic.substack.com' target='_blank' rel='noopener noreferrer'>Subscribe</a>
				</div>
			</aside>

			<main class='main'>
				<section class='featured-writing' id='writing'>
					<p class='intro'>
						I build apps on AI, data science, and privacy to see what holds up beyond the hype.
						Each project goes end-to-end: design, engineering, analytics, and published analysis.
						<strong>Everything is open source.</strong>
					</p>

					{
						featuredPost && (
							<a class='featured-article' href={featuredPost.link} target='_blank' rel='noopener noreferrer'>
								<span class='badge'>Latest Post</span>
								<h3>{featuredPost.title}</h3>
								<p class='excerpt'>{featuredPost.description}</p>
								<span class='meta'>{formatLongDate(featuredPost.date)} · essay</span>
							</a>
						)
					}

					<div class='writing-list'>
						{
							recentPosts.map((post) => (
								<a class='writing-item' href={post.link} target='_blank' rel='noopener noreferrer'>
									<span class='date'>{formatShortDate(post.date)}</span>
									<div class='title-col'>
										<h4>{post.title}</h4>
										<p class='desc'>{post.description}</p>
									</div>
								</a>
							))
						}
					</div>
					<a class='view-all' href='/analysis'>View all posts →</a>
				</section>

				<section class='projects-section' id='projects'>
					<div class='section-header'>
						<h2>Projects</h2>
						<div class='line'></div>
					</div>

					<div class='project-grid'>
						{
							featuredProject && (
								<div class='project-card featured'>
									<div>
										<div class='status'><span class='dot'></span> Live · Collecting Data</div>
										<h3>{featuredProject.name}</h3>
										<p class='desc'>{featuredProject.description}</p>
										<div class='tags'>
											{featuredProject.tags.map((tag) => <span class='tag'>{tag.name}</span>)}
										</div>
									</div>
									<div>
										<div class='project-stats featured-stats'>
											{projectStats[featuredProject.id]?.map((stat) => (
												<div class='project-stat'><span class='val'>{stat.value}</span> {stat.label}</div>
											))}
											<div class='project-links'>
												<a href={featuredProject.url}>Play it →</a>
												<a href={projectHref(featuredProject.id)}>Read analysis →</a>
												<a href={repoHref(featuredProject.id)} target='_blank' rel='noopener noreferrer'>View code →</a>
											</div>
										</div>
									</div>
								</div>
							)
						}

						{
							conceptProjects.map((project) => (
								<div class='project-card'>
									<div class:list={['status', project.status === 'in-progress' && 'status-accent']}>
										<span class='dot'></span> {statusLabel(project.status)}
									</div>
									<h3>{project.name}</h3>
									<p class='desc'>{project.shortDescription || project.description}</p>
									<div class='tags'>
										{project.tags.map((tag) => <span class='tag'>{tag.name}</span>)}
									</div>
									{projectStats[project.id] && (
										<div class='project-stats'>
											{projectStats[project.id].map((stat) => (
												<div class='project-stat'><span class='val'>{stat.value}</span> {stat.label}</div>
											))}
										</div>
									)}
								</div>
							))
						}
					</div>
				</section>

				<section class='github-section' id='github'>
					<div class='github-header'>
						<h2>Open Source</h2>
						<a class='gh-link' href='https://github.com/eeshansrivastava89' target='_blank' rel='noopener noreferrer'>@eeshansrivastava89 →</a>
					</div>

					<div class='contribution-grid' aria-hidden='true'>
						{
							[
								['', 'l1', '', 'l2', ''],
								['l1', '', 'l1', '', 'l1'],
								['', 'l2', 'l1', 'l3', 'l1'],
								['l1', 'l1', '', 'l2', ''],
								['', 'l1', 'l2', 'l1', 'l3'],
								['l2', '', 'l1', '', 'l1'],
								['l1', 'l3', 'l2', 'l1', ''],
								['', 'l1', '', 'l2', 'l1'],
								['l2', 'l1', 'l3', '', 'l2'],
								['l1', '', 'l1', 'l1', ''],
								['', 'l2', '', 'l3', 'l2'],
								['l3', 'l1', 'l2', 'l1', 'l1'],
								['l1', '', 'l1', '', 'l2'],
								['', 'l2', 'l3', 'l1', ''],
								['l1', 'l1', '', 'l2', 'l3'],
								['l2', 'l3', 'l1', '', 'l1'],
								['', 'l1', 'l2', 'l2', ''],
								['l2', '', 'l1', 'l3', 'l2'],
								['l1', 'l2', '', 'l1', 'l1'],
								['', 'l3', 'l2', '', 'l2'],
								['l2', 'l1', 'l3', 'l2', ''],
								['l1', '', 'l1', 'l1', 'l3'],
								['l3', 'l2', 'l4', 'l2', 'l1'],
								['l2', 'l3', 'l2', 'l4', 'l3'],
								['l3', 'l4', 'l3', 'l2', 'l4'],
								['l4', 'l3', 'l4', 'l3', 'l2']
							].map((week) => (
								<div class='contrib-week'>
									{week.map((level) => <div class:list={['contrib-day', level]}></div>)}
								</div>
							))
						}
					</div>

					<div class='recent-commits'>
						{
							recentCommits.map((commit) => (
								<div class='commit-item'>
									<div class='msg'><span class='repo'>{commit.repo}</span> · {commit.msg}</div>
									<span class='time'>{commit.time}</span>
								</div>
							))
						}
					</div>
				</section>

				<section class='analysis-section' id='analysis'>
					<div class='section-header'>
						<h2>Published Analysis</h2>
						<div class='line'></div>
					</div>

					<div class='analysis-list'>
						{
							conceptAnalysis.map((item, index) => (
								<a class='analysis-item' href={item.link} target={item.type === 'post' ? '_blank' : undefined} rel={item.type === 'post' ? 'noopener noreferrer' : undefined}>
									<div class='analysis-icon'>{['📊', '📈', '🔬', '🤖'][index % 4]}</div>
									<div class='info'>
										<h4>{item.title}</h4>
										<div class='meta'>
											{item.projectId || 'cross-project'} · {item.description || 'analysis'} · {formatLongDate(item.date)}
										</div>
									</div>
									<span class='arrow'>→</span>
								</a>
							))
						}
					</div>
				</section>

				<section class='recognition-section' id='recognition'>
					<div class='section-header'>
						<h2>Recognition</h2>
						<div class='line'></div>
					</div>

					<div class='recognition-grid'>
						{
							recognitionItems.map((item) => (
								<div class='recognition-item'>
									<div class='type'>{item.type}</div>
									<div class='detail'>{item.detail}</div>
									<div class='year'>{item.year}</div>
								</div>
							))
						}
					</div>
				</section>

				<footer class='footer'>
					<div class='quote'>"Just someone who likes making things work, learning by doing, and working with smart people."</div>
					<div class='location'>Seattle, WA</div>
				</footer>
			</main>
		</div>
	</body>
</html>

<style>
	:global(body.hub-v2-body) {
		--bg: #0a0a0b;
		--bg-raised: #111113;
		--bg-surface: #18181b;
		--bg-hover: #1e1e22;
		--text: #ededef;
		--text-secondary: #8b8b8e;
		--text-muted: #5a5a5d;
		--accent: #e8a44a;
		--accent-dim: #e8a44a33;
		--accent-hover: #f0b560;
		--blue: #5b9fd4;
		--green: #4ade80;
		--border: #2a2a2e;
		--border-subtle: #1e1e22;
		--radius: 6px;
		margin: 0;
		padding-top: 30px;
		font-family: 'Inter', -apple-system, sans-serif;
		background: var(--bg);
		color: var(--text);
		line-height: 1.6;
		font-size: 14px;
		-webkit-font-smoothing: antialiased;
	}

	:global(body.hub-v2-body *) {
		box-sizing: border-box;
	}

	a {
		color: var(--text);
		text-decoration: none;
	}

	a:hover {
		color: var(--accent);
	}

	.mockup-banner {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding: 6px;
		background: var(--accent);
		color: var(--bg);
		text-align: center;
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 1px;
		text-transform: uppercase;
	}

	.page-shell {
		display: grid;
		grid-template-columns: 320px 1fr;
		min-height: 100vh;
		max-width: 1280px;
		margin: 0 auto;
	}

	.sidebar {
		position: sticky;
		top: 30px;
		height: calc(100vh - 30px);
		overflow: hidden;
		padding: 28px 24px 20px 32px;
		border-right: 1px solid var(--border-subtle);
		display: flex;
		flex-direction: column;
	}

	.identity {
		margin-bottom: 20px;
	}

	.identity h1,
	.featured-article h3,
	.section-header h2,
	.github-header h2 {
		font-family: 'Playfair Display', serif;
	}

	.identity h1 {
		margin: 0 0 4px;
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -0.5px;
		line-height: 1.2;
	}

	.identity .role {
		margin-bottom: 10px;
		font-size: 12px;
		color: var(--text-secondary);
		line-height: 1.45;
	}

	.identity .role strong {
		color: var(--text);
		font-weight: 500;
	}

	.social-row {
		display: flex;
		gap: 10px;
	}

	.social-row a,
	.sidebar-nav a,
	.gh-link,
	.section-label,
	.project-card .status,
	.tag,
	.project-stat,
	.commit-item .time,
	.recognition-item .type,
	.analysis-item .info .meta,
	.featured-article .badge,
	.featured-article .meta,
	.writing-item .date,
	.location {
		font-family: 'JetBrains Mono', monospace;
	}

	.social-row a {
		color: var(--text-muted);
		font-size: 11px;
		padding: 3px 0;
		border-bottom: 1px solid transparent;
		transition: all 0.15s;
	}

	.social-row a:hover {
		color: var(--text);
		border-bottom-color: var(--text-muted);
	}

	.sidebar-nav {
		display: flex;
		flex-direction: column;
		gap: 1px;
		margin-bottom: 16px;
		padding-top: 16px;
		border-top: 1px solid var(--border-subtle);
	}

	.sidebar-nav a {
		font-size: 12px;
		color: var(--text-muted);
		padding: 4px 10px;
		border-radius: var(--radius);
		transition: all 0.15s;
		font-weight: 450;
	}

	.sidebar-nav a:hover,
	.sidebar-nav a.active {
		color: var(--text);
		background: var(--bg-surface);
	}

	.credentials,
