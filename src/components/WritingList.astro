---
import type { SubstackPost } from '@/lib/substack'

interface Props {
	posts: SubstackPost[]
}

const { posts } = Astro.props
const featured = posts[0]
const rest = posts.slice(1, 5)

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
}
---

{featured && (
	<a class='writing-featured' href={featured.link} target='_blank' rel='noopener noreferrer'>
		<span class='writing-badge'>Latest Post</span>
		<h3 class='writing-featured-title'>{featured.title}</h3>
		<p class='writing-featured-excerpt'>{featured.description}</p>
		<span class='writing-featured-meta'>
			{formatDate(featured.pubDate)} · Asymptotic
		</span>
	</a>
)}

<div class='writing-list'>
	{rest.map((post) => (
		<a class='writing-item' href={post.link} target='_blank' rel='noopener noreferrer'>
			<span class='writing-date'>{formatDate(post.pubDate)}</span>
			<div class='writing-col'>
				<h4 class='writing-title'>{post.title}</h4>
				<p class='writing-desc'>{post.description}</p>
			</div>
		</a>
	))}
</div>

<a class='writing-view-all' href='/analysis'>View all posts →</a>

<style>
	.writing-featured {
		display: block;
		padding: 24px;
		background: hsl(var(--muted));
		border: 1px solid hsl(var(--border));
		border-radius: 8px;
		margin-bottom: 16px;
		transition: all 0.2s;
		text-decoration: none;
		color: inherit;
		overflow: hidden;
	}

	.writing-featured:hover {
		border-color: hsl(var(--foreground) / 0.2);
		transform: translateY(-1px);
	}

	.writing-badge {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		color: hsl(var(--muted-foreground));
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-bottom: 10px;
		display: block;
	}

	.writing-featured-title {
		font-family: 'Playfair Display', serif;
		font-size: 20px;
		font-weight: 600;
		line-height: 1.3;
		margin-bottom: 8px;
		color: hsl(var(--foreground));
	}

	.writing-featured-excerpt {
		font-size: 14px;
		color: hsl(var(--muted-foreground));
		line-height: 1.6;
		margin-bottom: 12px;
	}

	.writing-featured-meta {
		display: block;
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		color: hsl(var(--muted-foreground));
		margin-top: 4px;
	}

	.writing-list {
		display: flex;
		flex-direction: column;
	}

	.writing-item {
		display: grid;
		grid-template-columns: 72px 1fr;
		gap: 16px;
		align-items: baseline;
		padding: 12px;
		margin: 0 -12px;
		border-bottom: 1px solid hsl(var(--border));
		border-radius: 6px;
		transition: background 0.15s;
		text-decoration: none;
		color: inherit;
	}

	.writing-item:hover {
		background: hsl(var(--muted));
		border-color: transparent;
	}

	.writing-date {
		font-family: 'JetBrains Mono', monospace;
		font-size: 12px;
		color: hsl(var(--muted-foreground));
		white-space: nowrap;
	}

	.writing-title {
		font-size: 14px;
		font-weight: 500;
		margin-bottom: 2px;
		line-height: 1.4;
		color: hsl(var(--foreground));
	}

	.writing-desc {
		font-size: 13px;
		color: hsl(var(--muted-foreground));
		line-height: 1.5;
	}

	.writing-view-all {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		margin-top: 16px;
		font-size: 13px;
		color: hsl(var(--muted-foreground));
		font-weight: 450;
		text-decoration: none;
	}

	.writing-view-all:hover {
		color: hsl(var(--foreground));
	}
</style>
