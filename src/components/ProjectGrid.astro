---
import type { Project } from '@/lib/projects'

interface Props {
	projects: Project[]
	featured?: Project
}

const { projects, featured } = Astro.props
const gridProjects = projects.filter(p => p.id !== featured?.id)
---

<div class='project-grid'>
	{featured && (
		<a class='project-card project-featured' href={featured.url} target={featured.external ? '_blank' : undefined} rel={featured.external ? 'noopener noreferrer' : undefined}>
			<div>
				<div class='project-status'>
					<span class='project-dot'></span>
					{featured.status === 'live' ? 'Live · Collecting Data' : featured.status}
				</div>
				<h3 class='project-card-title'>{featured.name}</h3>
				<p class='project-card-desc'>{featured.description}</p>
				<div class='project-tags'>
					{featured.tags.slice(0, 5).map(tag => (
						<span class='project-tag'>{tag.name}</span>
					))}
				</div>
			</div>
			<div class='project-featured-stats'>
				<div style='margin-top:8px;'>
					<span class='project-cta'>Try it →</span>
				</div>
			</div>
		</a>
	)}

	{gridProjects.map(project => (
		<a class='project-card' href={project.url} target={project.external ? '_blank' : undefined} rel={project.external ? 'noopener noreferrer' : undefined}>
			<div class='project-status'>
				<span class='project-dot' data-status={project.status}></span>
				{project.status === 'live' ? 'Live' : project.status === 'in-progress' ? 'Building' : project.status}
			</div>
			<h3 class='project-card-title'>{project.name}</h3>
			<p class='project-card-desc'>{project.shortDescription}</p>
			<div class='project-tags'>
				{project.tags.slice(0, 3).map(tag => (
					<span class='project-tag'>{tag.name}</span>
				))}
			</div>
			</a>
	))}
</div>

<style>
	.project-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}

	.project-card {
		padding: 20px;
		background: hsl(var(--muted));
		border: 1px solid hsl(var(--border));
		border-radius: 8px;
		transition: all 0.2s;
		cursor: pointer;
		text-decoration: none;
		color: inherit;
	}

	.project-card:hover {
		border-color: hsl(var(--foreground) / 0.2);
		transform: translateY(-1px);
	}

	.project-featured {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 24px;
	}

	.project-status {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-size: 11px;
		font-family: 'JetBrains Mono', monospace;
		color: #16a34a;
		margin-bottom: 10px;
	}
	:global(.dark) .project-status {
		color: #4ade80;
	}

	.project-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #16a34a;
		animation: pulse 2s infinite;
	}
	:global(.dark) .project-dot {
		background: #4ade80;
	}

	.project-dot[data-status='in-progress'] {
		background: #fbbf24;
		animation: none;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	.project-card-title {
		font-size: 16px;
		font-weight: 600;
		margin-bottom: 6px;
		line-height: 1.3;
		color: hsl(var(--foreground));
	}

	.project-card-desc {
		font-size: 13px;
		color: hsl(var(--muted-foreground));
		line-height: 1.5;
		margin-bottom: 14px;
	}

	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-bottom: 14px;
	}

	.project-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		padding: 3px 8px;
		background: hsl(var(--background));
		border: 1px solid hsl(var(--border));
		border-radius: 4px;
		color: hsl(var(--muted-foreground));
	}

	.project-featured-stats {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}


	.project-cta {
		font-size: 13px;
		color: hsl(var(--foreground));
		font-weight: 500;
	}

	@media (max-width: 900px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
		.project-featured {
			grid-template-columns: 1fr;
		}
	}
</style>
