---
import type { TocEntry } from '@/lib/toc'

interface Props {
  title: string
  toc: TocEntry[]
}

const { title, toc } = Astro.props
---

<aside class='article-sidebar'>
  <div class='article-sidebar-top'>
    <a href='/' class='article-sidebar-back'>← eeshans.com</a>
    <p class='article-sidebar-title'>{title}</p>
  </div>

  <nav class='article-toc' id='article-toc'>
    {toc.map(entry => (
      <a
        href={`#${entry.id}`}
        class={`toc-link ${entry.level >= 3 ? 'toc-indent' : ''}`}
        data-toc-id={entry.id}
      >
        {entry.text}
      </a>
    ))}
  </nav>

  <div class='article-sidebar-bottom'>
    <hr class='article-sidebar-rule' />
    <a
      href='https://theasymptotic.substack.com/subscribe'
      target='_blank'
      rel='noopener noreferrer'
      class='article-sidebar-follow'
    >
      Follow Asymptotic for updates →
    </a>
  </div>
</aside>

<style>
  .article-sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    padding: 28px 24px 20px 32px;
    border-right: 1px solid hsl(var(--border));
    display: flex;
    flex-direction: column;
    font-family: 'Inter', -apple-system, sans-serif;
  }

  .article-sidebar::-webkit-scrollbar { width: 0; }

  .article-sidebar-top {
    margin-bottom: 16px;
  }

  .article-sidebar-back {
    font-size: 12px;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    display: inline-block;
    margin-bottom: 12px;
    transition: color 0.15s;
  }

  .article-sidebar-back:hover {
    color: hsl(var(--foreground));
  }

  .article-sidebar-title {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
    color: hsl(var(--foreground));
  }

  .article-toc {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 10px 0;
    border-top: 1px solid hsl(var(--border));
    flex: 1;
    overflow-y: auto;
  }

  .article-toc::-webkit-scrollbar { width: 0; }

  .toc-link {
    font-size: 12px;
    color: hsl(var(--muted-foreground));
    padding: 4px 10px;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.15s;
    font-weight: 400;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .toc-link:hover {
    color: hsl(var(--foreground));
    background: hsl(var(--muted));
  }

  .toc-link.active {
    color: hsl(var(--foreground));
    background: hsl(var(--muted));
    font-weight: 450;
  }

  .toc-indent {
    padding-left: 22px;
    font-size: 11px;
  }

  .article-sidebar-bottom {
    padding-top: 10px;
  }

  .article-sidebar-rule {
    border: none;
    border-top: 1px solid hsl(var(--border));
    margin: 0 0 10px 0;
  }

  .article-sidebar-follow {
    font-size: 11px;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    transition: color 0.15s;
  }

  .article-sidebar-follow:hover {
    color: hsl(var(--foreground));
  }

  @media (max-width: 900px) {
    .article-sidebar {
      display: none;
    }
  }
</style>

<script>
  // Smooth scroll
  document.querySelectorAll('#article-toc a').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href')
      if (href?.startsWith('#')) {
        e.preventDefault()
        const target = document.querySelector(href)
        target?.scrollIntoView({ behavior: 'smooth' })
      }
    })
  })

  // Scroll spy — same pattern as homepage sidebar
  const headings = document.querySelectorAll('.substack-content h1[id], .substack-content h2[id], .substack-content h3[id]')
  const tocLinks = document.querySelectorAll('#article-toc a[data-toc-id]')

  const tocObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(link => link.classList.remove('active'))
          const activeLink = document.querySelector(
            `#article-toc a[data-toc-id="${entry.target.id}"]`
          )
          activeLink?.classList.add('active')
        }
      })
    },
    { rootMargin: '-10% 0px -70% 0px' }
  )

  headings.forEach(h => tocObserver.observe(h))
</script>
