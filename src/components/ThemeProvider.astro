<script is:inline>
	const lightModePref = window.matchMedia('(prefers-color-scheme: light)')

	// Theme format: "coffee-light", "coffee-dark", "catppuccin-light", etc.
	// Stored in localStorage as "site-theme"
	function getTheme() {
		const stored = localStorage.getItem('site-theme')
		if (stored) return stored
		// Default: coffee, mode from system preference
		return 'coffee-' + (lightModePref.matches ? 'light' : 'dark')
	}

	function setTheme(theme) {
		localStorage.setItem('site-theme', theme)
		const root = document.documentElement
		root.setAttribute('data-theme', theme)

		// Set .dark class for Tailwind dark: variants
		if (theme.endsWith('-dark')) {
			root.classList.add('dark')
		} else {
			root.classList.remove('dark')
		}

		// Update switcher button states
		const family = theme.replace(/-light$/, '').replace(/-dark$/, '')
		document.querySelectorAll('[data-theme-btn]').forEach(btn => {
			btn.classList.toggle('active', btn.getAttribute('data-theme-btn') === family)
		})

		// Update mode indicator on active button
		document.querySelectorAll('[data-theme-btn]').forEach(btn => {
			const indicator = btn.querySelector('.theme-mode-indicator')
			if (indicator && btn.getAttribute('data-theme-btn') === family) {
				indicator.textContent = theme.endsWith('-dark') ? '☽' : '☼'
			}
		})
	}

	// Toggle: clicking a theme button cycles between its light and dark variant
	window.__toggleTheme = function(family) {
		const current = getTheme()
		const currentFamily = current.replace(/-light$/, '').replace(/-dark$/, '')
		const currentMode = current.endsWith('-dark') ? 'dark' : 'light'

		if (family === currentFamily) {
			// Same family — toggle mode
			setTheme(family + '-' + (currentMode === 'light' ? 'dark' : 'light'))
		} else {
			// Different family — switch to it, keep current mode
			setTheme(family + '-' + currentMode)
		}
	}

	// Initial setup
	setTheme(getTheme())

	// View Transitions
	document.addEventListener('astro:after-swap', () => setTheme(getTheme()))

	// System preference change
	lightModePref.addEventListener('change', (e) => {
		const current = getTheme()
		const family = current.replace(/-light$/, '').replace(/-dark$/, '')
		setTheme(family + '-' + (e.matches ? 'light' : 'dark'))
	})

	// Legacy theme-change event (for Header toggle on non-homepage pages)
	document.addEventListener('theme-change', (e) => {
		const current = getTheme()
		const family = current.replace(/-light$/, '').replace(/-dark$/, '')
		setTheme(family + '-' + e.detail.theme)
	})
</script>
