<script is:inline>
	const lightModePref = window.matchMedia('(prefers-color-scheme: light)')

	function getMode() {
		return localStorage.getItem('theme') || (lightModePref.matches ? 'light' : 'dark')
	}

	function getThemeName() {
		return localStorage.getItem('theme-name') || 'coffee'
	}

	function setMode(newMode) {
		if (newMode !== 'light' && newMode !== 'dark') return
		localStorage.setItem('theme', newMode)
		const root = document.documentElement
		if (newMode === 'dark') {
			root.classList.add('dark')
		} else {
			root.classList.remove('dark')
		}
	}

	function setThemeName(name) {
		localStorage.setItem('theme-name', name)
		document.documentElement.setAttribute('data-theme', name)
		// Update switcher UI if present
		document.querySelectorAll('[data-theme-btn]').forEach(btn => {
			btn.classList.toggle('active', btn.getAttribute('data-theme-btn') === name)
		})
	}

	// Initial setup
	setMode(getMode())
	setThemeName(getThemeName())

	// View Transitions hook
	document.addEventListener('astro:after-swap', () => {
		setMode(getMode())
		setThemeName(getThemeName())
	})

	// Listen for mode toggle
	document.addEventListener('theme-change', (e) => {
		setMode(e.detail.theme)
	})

	// Listen for theme-name change
	document.addEventListener('theme-name-change', (e) => {
		setThemeName(e.detail.name)
	})

	lightModePref.addEventListener('change', (e) => setMode(e.matches ? 'light' : 'dark'))
</script>
