---
/**
 * Theme switcher — 3 buttons, each toggles between its own light/dark pair.
 * | Theme | Coffee | Catppuccin | Classic |
 * Click a button: switches to that theme family (keeping current mode).
 * Click the active button: toggles light ↔ dark within that family.
 */
---

<div class='theme-bar'>
	<span class='theme-label'>Theme</span>
	<div class='theme-buttons'>
		<button data-theme-btn='coffee' class='theme-btn' title='Coffee — toggle light/dark' onclick='window.__toggleTheme("coffee")'>
			<span class='theme-dot' style='background: hsl(30, 55%, 45%);'></span>
			<span class='theme-btn-name'>Coffee</span>
			<span class='theme-mode-indicator'></span>
		</button>
		<button data-theme-btn='catppuccin' class='theme-btn' title='Catppuccin — toggle light/dark' onclick='window.__toggleTheme("catppuccin")'>
			<span class='theme-dot' style='background: hsl(267, 84%, 70%);'></span>
			<span class='theme-btn-name'>Catppuccin</span>
			<span class='theme-mode-indicator'></span>
		</button>
		<button data-theme-btn='classic' class='theme-btn' title='Classic — toggle light/dark' onclick='window.__toggleTheme("classic")'>
			<span class='theme-dot' style='background: hsl(240, 5.9%, 50%);'></span>
			<span class='theme-btn-name'>Classic</span>
			<span class='theme-mode-indicator'></span>
		</button>
	</div>
</div>

<style>
	.theme-bar {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 6px 0;
		margin-top: 10px;
	}

	.theme-label {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		color: hsl(var(--muted-foreground));
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.theme-buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 2px;
		background: hsl(var(--muted));
		border-radius: 6px;
		padding: 2px;
	}

	.theme-btn {
		display: flex;
		align-items: center;
		gap: 3px;
		padding: 3px 6px;
		border: none;
		border-radius: 4px;
		background: transparent;
		cursor: pointer;
		transition: all 0.15s;
		font-family: 'Inter', sans-serif;
		color: hsl(var(--muted-foreground));
	}

	.theme-btn:hover {
		background: hsl(var(--background));
		color: hsl(var(--foreground));
	}

	.theme-btn.active {
		background: hsl(var(--background));
		color: hsl(var(--foreground));
		box-shadow: 0 1px 2px hsl(var(--border));
	}

	.theme-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.theme-btn-name {
		font-size: 11px;
		font-weight: 450;
	}

	.theme-mode-indicator {
		font-size: 10px;
		width: 14px;
		text-align: center;
		opacity: 0;
		transition: opacity 0.15s;
	}

	.theme-btn.active .theme-mode-indicator {
		opacity: 0.6;
	}

	@media (max-width: 900px) {
		.theme-btn-name { display: none; }
		.theme-btn { padding: 4px 6px; }
		.theme-mode-indicator { display: none; }
	}
</style>

<script>
	// Set active button state on page load (ThemeProvider runs in <head> before these elements exist)
	function syncThemeButtons() {
		const theme = localStorage.getItem('site-theme') || 'coffee-light'
		const family = theme.replace(/-light$/, '').replace(/-dark$/, '')
		const isDark = theme.endsWith('-dark')
		document.querySelectorAll('[data-theme-btn]').forEach(btn => {
			const isActive = btn.getAttribute('data-theme-btn') === family
			btn.classList.toggle('active', isActive)
			const indicator = btn.querySelector('.theme-mode-indicator')
			if (indicator) {
				indicator.textContent = isActive ? (isDark ? '☽' : '☼') : ''
			}
		})
	}
	// Run immediately, and on Astro page transitions
	syncThemeButtons()
	document.addEventListener('astro:after-swap', syncThemeButtons)
</script>
