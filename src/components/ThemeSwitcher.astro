---
/**
 * Theme switcher bar — 3 themes × light/dark toggle
 * Each theme button selects the color scheme.
 * The sun/moon icon toggles light/dark within the active theme.
 */
---

<div class='theme-bar'>
	<span class='theme-label'>Theme</span>
	<div class='theme-buttons'>
		<button data-theme-btn='coffee' class='theme-btn' title='Coffee theme'>
			<span class='theme-dot' style='background: hsl(30, 55%, 45%);'></span>
			<span class='theme-btn-label'>Coffee</span>
		</button>
		<button data-theme-btn='cappuccino' class='theme-btn' title='Cappuccino theme'>
			<span class='theme-dot' style='background: hsl(16, 50%, 48%);'></span>
			<span class='theme-btn-label'>Cappuccino</span>
		</button>
		<button data-theme-btn='basic' class='theme-btn' title='Basic theme'>
			<span class='theme-dot' style='background: hsl(240, 5.9%, 50%);'></span>
			<span class='theme-btn-label'>Basic</span>
		</button>
	</div>
	<button class='mode-toggle' id='themeModeToggle' title='Toggle light/dark'>
		<svg class='mode-icon sun' xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
			<circle cx='12' cy='12' r='5'/>
			<line x1='12' y1='1' x2='12' y2='3'/><line x1='12' y1='21' x2='12' y2='23'/>
			<line x1='4.22' y1='4.22' x2='5.64' y2='5.64'/><line x1='18.36' y1='18.36' x2='19.78' y2='19.78'/>
			<line x1='1' y1='12' x2='3' y2='12'/><line x1='21' y1='12' x2='23' y2='12'/>
			<line x1='4.22' y1='19.78' x2='5.64' y2='18.36'/><line x1='18.36' y1='5.64' x2='19.78' y2='4.22'/>
		</svg>
		<svg class='mode-icon moon' xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
			<path d='M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z'/>
		</svg>
	</button>
</div>

<script>
	// Theme name buttons
	document.querySelectorAll('[data-theme-btn]').forEach(btn => {
		btn.addEventListener('click', () => {
			const name = btn.getAttribute('data-theme-btn')
			if (name) {
				document.dispatchEvent(new CustomEvent('theme-name-change', { detail: { name } }))
			}
		})
	})

	// Mode toggle
	document.getElementById('themeModeToggle')?.addEventListener('click', () => {
		const current = localStorage.getItem('theme') || 'dark'
		document.dispatchEvent(new CustomEvent('theme-change', {
			detail: { theme: current === 'light' ? 'dark' : 'light' }
		}))
	})

	// Set initial active state
	const currentTheme = localStorage.getItem('theme-name') || 'coffee'
	document.querySelectorAll('[data-theme-btn]').forEach(btn => {
		btn.classList.toggle('active', btn.getAttribute('data-theme-btn') === currentTheme)
	})
</script>

<style>
	.theme-bar {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 6px 0;
		margin-top: 10px;
	}

	.theme-label {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		color: hsl(var(--muted-foreground));
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.theme-buttons {
		display: flex;
		gap: 2px;
		background: hsl(var(--muted));
		border-radius: 6px;
		padding: 2px;
	}

	.theme-btn {
		display: flex;
		align-items: center;
		gap: 4px;
		padding: 3px 8px;
		border: none;
		border-radius: 4px;
		background: transparent;
		cursor: pointer;
		transition: all 0.15s;
		font-family: 'Inter', sans-serif;
		color: hsl(var(--muted-foreground));
	}

	.theme-btn:hover {
		background: hsl(var(--background));
		color: hsl(var(--foreground));
	}

	.theme-btn.active {
		background: hsl(var(--background));
		color: hsl(var(--foreground));
		box-shadow: 0 1px 2px hsl(var(--border));
	}

	.theme-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.theme-btn-label {
		font-size: 11px;
		font-weight: 450;
	}

	.mode-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border: 1px solid hsl(var(--border));
		border-radius: 6px;
		background: hsl(var(--background));
		cursor: pointer;
		color: hsl(var(--muted-foreground));
		transition: all 0.15s;
		margin-left: auto;
	}

	.mode-toggle:hover {
		color: hsl(var(--foreground));
		border-color: hsl(var(--foreground) / 0.3);
	}

	/* Show sun in dark mode, moon in light mode */
	.mode-icon.sun { display: none; }
	.mode-icon.moon { display: block; }
	:global(.dark) .mode-icon.sun { display: block; }
	:global(.dark) .mode-icon.moon { display: none; }

	@media (max-width: 900px) {
		.theme-btn-label { display: none; }
		.theme-btn { padding: 3px 6px; }
	}
</style>
