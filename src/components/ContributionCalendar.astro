---
import type { ContributionWeek } from '@/lib/github'

interface Props {
  weeks: ContributionWeek[]
  totalContributions: number
}

const { weeks, totalContributions } = Astro.props
---

<div class='contrib-container'>
  <div class='contrib-header'>
    <span class='contrib-count'>{totalContributions.toLocaleString()} contributions in the last year</span>
  </div>
  <div class='contrib-grid' style={`--weeks: ${weeks.length};`}>
    {weeks.map(week => (
      <div class='contrib-week'>
        {week.contributionDays.map(day => (
          <div
            class='contrib-day'
            style={`background-color: ${day.contributionCount === 0 ? 'hsl(var(--muted))' : day.color};`}
            title={`${day.date}: ${day.contributionCount} contribution${day.contributionCount !== 1 ? 's' : ''}`}
          />
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .contrib-container {
    margin-bottom: 16px;
  }

  .contrib-header {
    margin-bottom: 8px;
  }

  .contrib-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: hsl(var(--muted-foreground));
  }

  .contrib-grid {
    display: grid;
    grid-template-columns: repeat(var(--weeks), minmax(0, 1fr));
    gap: 3px;
    width: 100%;
    align-items: start;
  }

  .contrib-week {
    display: grid;
    grid-template-rows: repeat(7, minmax(0, 1fr));
    gap: 3px;
    min-width: 0;
  }

  .contrib-day {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 2px;
    outline: 1px solid hsl(var(--border) / 0.3);
  }

  @media (max-width: 900px) {
    .contrib-grid {
      gap: 2px;
    }

    .contrib-week {
      gap: 2px;
    }
  }
</style>
