---
import type { RecentActivity, ActivityTotals } from '@/lib/github'

interface Props {
  activities: RecentActivity[]
  totals?: ActivityTotals
}

const { activities, totals } = Astro.props

// Categorize activities
const commits = activities.filter(a => a.category === 'commit')
const repos = activities.filter(a => a.category === 'repo')
const issues = activities.filter(a => a.category === 'issue')
const prs = activities.filter(a => a.category === 'pr')

// Use real totals from GraphQL, fall back to counting returned items
const totalCommits = totals?.commits || commits.reduce((sum, a) => {
  const match = a.message.match(/^(\d+)/)
  return sum + (match ? parseInt(match[1]) : 0)
}, 0)
const totalIssues = totals?.issues || issues.length
const totalPRs = totals?.prs || prs.length
const totalRepos = totals?.repos || repos.length
---

{activities.length > 0 ? (
  <div class='timeline'>
    {/* Commits summary */}
    {commits.length > 0 && (
      <div class='timeline-section'>
        <div class='timeline-section-header'>
          <span class='timeline-icon'>
            <svg viewBox='0 0 16 16' fill='currentColor' width='16' height='16'><path d='M10.5 7.75a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Zm1.43.75a4.002 4.002 0 0 1-7.86 0H.75a.75.75 0 0 1 0-1.5h3.32a4.002 4.002 0 0 1 7.86 0h3.32a.75.75 0 0 1 0 1.5Zm-1.43-.75a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z'/></svg>
          </span>
          <span>{totalCommits.toLocaleString()} commits in {commits.length} repositor{commits.length === 1 ? 'y' : 'ies'}</span>
        </div>
        <div class='timeline-items'>
          {commits.map(item => (
            <a href={item.url} target='_blank' rel='noopener noreferrer' class='timeline-row'>
              <span class='timeline-repo'>{item.repo}</span>
              <span class='timeline-detail'>{item.message}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    {/* New repos */}
    {repos.length > 0 && (
      <div class='timeline-section'>
        <div class='timeline-section-header'>
          <span class='timeline-icon'>
            <svg viewBox='0 0 16 16' fill='currentColor' width='16' height='16'><path d='M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z'/></svg>
          </span>
          <span>Created {totalRepos} repositor{totalRepos === 1 ? 'y' : 'ies'}</span>
        </div>
        <div class='timeline-items'>
          {repos.map(item => (
            <a href={item.url} target='_blank' rel='noopener noreferrer' class='timeline-row'>
              <span class='timeline-repo'>{item.repo}</span>
              <span class='timeline-detail'>{item.message.replace('Created repository', '').trim()}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Issues */}
    {issues.length > 0 && (
      <div class='timeline-section'>
        <div class='timeline-section-header'>
          <span class='timeline-icon'>
            <svg viewBox='0 0 16 16' fill='currentColor' width='16' height='16'><path d='M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z'/><path d='M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0Z'/></svg>
          </span>
          <span>Opened {totalIssues} issue{totalIssues === 1 ? '' : 's'}</span>
        </div>
        <div class='timeline-items'>
          {issues.map(item => (
            <a href={item.url} target='_blank' rel='noopener noreferrer' class='timeline-row'>
              <span class='timeline-repo'>{item.repo}</span>
              <span class='timeline-detail'>{item.message.replace('Opened issue: ', '')}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Pull Requests */}
    {prs.length > 0 && (
      <div class='timeline-section'>
        <div class='timeline-section-header'>
          <span class='timeline-icon'>
            <svg viewBox='0 0 16 16' fill='currentColor' width='16' height='16'><path d='M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z'/></svg>
          </span>
          <span>Opened {totalPRs} pull request{totalPRs === 1 ? '' : 's'}</span>
        </div>
        <div class='timeline-items'>
          {prs.map(item => (
            <a href={item.url} target='_blank' rel='noopener noreferrer' class='timeline-row'>
              <span class='timeline-repo'>{item.repo}</span>
              <span class='timeline-detail'>{item.message.replace('Opened PR: ', '')}</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
) : (
  <p class='timeline-empty'>No recent activity.</p>
)}

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .timeline-section {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .timeline-section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: hsl(var(--foreground));
    padding-bottom: 6px;
    border-bottom: 1px solid hsl(var(--border));
  }

  .timeline-icon {
    display: flex;
    align-items: center;
    color: hsl(var(--muted-foreground));
  }

  .timeline-items {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .timeline-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 12px;
    padding: 5px 10px 5px 32px;
    border-radius: 6px;
    font-size: 13px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .timeline-row:hover {
    background: hsl(var(--muted));
  }

  .timeline-repo {
    color: hsl(210 60% 55%);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .timeline-detail {
    color: hsl(var(--muted-foreground));
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .timeline-empty {
    font-size: 13px;
    color: hsl(var(--muted-foreground));
    padding: 12px;
    text-align: center;
  }

  @media (max-width: 600px) {
    .timeline-row {
      grid-template-columns: 1fr;
      gap: 2px;
      padding-left: 10px;
    }
  }
</style>
