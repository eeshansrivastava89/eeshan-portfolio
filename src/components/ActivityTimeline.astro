---
import type { RecentActivity } from '@/lib/github'

interface Props {
  activities: RecentActivity[]
}

const { activities } = Astro.props

// Group activities by date
interface DayGroup {
  date: string
  label: string
  items: RecentActivity[]
}

function groupByDay(items: RecentActivity[]): DayGroup[] {
  const groups = new Map<string, RecentActivity[]>()

  for (const item of items) {
    const date = new Date(item.time)
    const key = date.toISOString().split('T')[0]
    if (!groups.has(key)) {
      groups.set(key, [])
    }
    groups.get(key)!.push(item)
  }

  const now = new Date()
  const today = now.toISOString().split('T')[0]
  const yesterday = new Date(now.getTime() - 86400000).toISOString().split('T')[0]

  return Array.from(groups.entries()).map(([date, items]) => {
    let label: string
    if (date === today) {
      label = 'Today'
    } else if (date === yesterday) {
      label = 'Yesterday'
    } else {
      label = new Date(date + 'T12:00:00').toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
      })
    }

    // Aggregate: if multiple pushes to same repo on same day, summarize
    const aggregated = aggregateItems(items)

    return { date, label, items: aggregated }
  })
}

function aggregateItems(items: RecentActivity[]): RecentActivity[] {
  // Group by repo + event category
  const byRepoCategory = new Map<string, RecentActivity[]>()

  for (const item of items) {
    const category = categorize(item.message)
    const key = `${category}:${item.repo}`

    if (!byRepoCategory.has(key)) {
      byRepoCategory.set(key, [])
    }
    byRepoCategory.get(key)!.push(item)
  }

  const result: RecentActivity[] = []

  for (const [key, group] of byRepoCategory) {
    if (group.length <= 2) {
      result.push(...group)
    } else {
      // Summarize repeated events
      const category = key.split(':')[0]
      const summaries: Record<string, string> = {
        push: `${group.length} commits`,
        issue: `${group.length} issue updates`,
        pr: `${group.length} PR updates`,
        comment: `${group.length} comments`,
        other: `${group.length} updates`,
      }
      result.push({
        repo: group[0].repo,
        message: summaries[category] || `${group.length} events`,
        time: group[0].time,
        url: group[0].url,
      })
    }
  }

  return result
}

function categorize(message: string): string {
  if (message.includes(' PR: ')) return 'pr'
  if (message.includes(' issue: ')) return 'issue'
  if (message.startsWith('Commented ')) return 'comment'
  if (message.startsWith('Created ')) return 'other'
  if (message.startsWith('Published ')) return 'other'
  return 'push'
}

function relativeTime(dateStr: string): string {
  const now = Date.now()
  const then = new Date(dateStr).getTime()
  const diff = now - then
  const mins = Math.floor(diff / 60000)
  if (mins < 60) return `${mins}m ago`
  const hours = Math.floor(mins / 60)
  if (hours < 24) return `${hours}h ago`
  const days = Math.floor(hours / 24)
  if (days < 7) return `${days}d ago`
  const weeks = Math.floor(days / 7)
  if (weeks < 5) return `${weeks}w ago`
  const months = Math.floor(days / 30)
  return `${months}mo ago`
}

const dayGroups = groupByDay(activities).slice(0, 5)
---

{dayGroups.length > 0 ? (
  <div class='timeline'>
    {dayGroups.map(group => (
      <div class='timeline-group'>
        <div class='timeline-date'>{group.label}</div>
        <div class='timeline-items'>
          {group.items.map(item => (
            <div class='timeline-item'>
              <div class='timeline-content'>
                {item.url ? (
                  <a href={item.url} target='_blank' rel='noopener noreferrer' class='timeline-repo'>{item.repo}</a>
                ) : (
                  <span class='timeline-repo'>{item.repo}</span>
                )}
                <span class='timeline-msg'>{item.message}</span>
              </div>
              <span class='timeline-time'>{relativeTime(item.time)}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
) : (
  <p class='timeline-empty'>No recent activity.</p>
)}

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .timeline-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .timeline-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    color: hsl(var(--muted-foreground));
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding-bottom: 4px;
    border-bottom: 1px solid hsl(var(--border));
    margin-bottom: 2px;
  }

  .timeline-items {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 13px;
    transition: background 0.15s;
  }

  .timeline-item:hover {
    background: hsl(var(--muted));
  }

  .timeline-content {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .timeline-repo {
    color: hsl(210 60% 55%);
    font-weight: 500;
    text-decoration: none;
  }

  .timeline-repo:hover {
    text-decoration: underline;
  }

  .timeline-msg {
    color: hsl(var(--muted-foreground));
  }

  .timeline-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: hsl(var(--muted-foreground));
    white-space: nowrap;
  }

  .timeline-empty {
    font-size: 13px;
    color: hsl(var(--muted-foreground));
    padding: 12px;
    text-align: center;
  }
</style>
