---
import { Icon } from 'astro-icon/components'
import SidebarNewsletter from './SidebarNewsletter.astro'

interface Props {
  title: string
  description: string
}

const { title, description } = Astro.props
---

<aside class='listing-sidebar'>
  <div class='listing-sidebar-top'>
    <nav class='listing-sidebar-nav'>
      <a href='/' class='listing-nav-link'>
        <Icon name='lucide:home' class='listing-sidebar-icon' />
        Home
      </a>
      <a href='/writing' class='listing-nav-link'>Writing</a>
      <a href='/projects' class='listing-nav-link'>Projects</a>
      <a href='/analysis' class='listing-nav-link'>Analysis</a>
    </nav>
    <h1 class='listing-sidebar-title'>{title}</h1>
    <p class='listing-sidebar-desc'>{description}</p>
  </div>

  <div class='listing-sidebar-filters'>
    <slot />
  </div>

  <div class='listing-sidebar-bottom'>
    <hr class='listing-sidebar-rule' />
    <SidebarNewsletter />
  </div>
</aside>

<style>
  .listing-sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    padding: 28px 24px 20px 32px;
    border-right: 1px solid hsl(var(--border));
    display: flex;
    flex-direction: column;
    font-family: 'Inter', -apple-system, sans-serif;
  }

  .listing-sidebar::-webkit-scrollbar { width: 0; }

  .listing-sidebar-top {
    margin-bottom: 16px;
  }

  .listing-sidebar-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 16px;
  }

  .listing-nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    padding: 3px 8px;
    border-radius: 6px;
    transition: all 0.15s;
  }

  .listing-nav-link:hover {
    color: hsl(var(--foreground));
    background: hsl(var(--muted));
  }

  .listing-sidebar-icon {
    width: 12px;
    height: 12px;
  }

  .listing-sidebar-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: hsl(var(--foreground));
    margin-bottom: 6px;
  }

  .listing-sidebar-desc {
    font-size: 12px;
    color: hsl(var(--muted-foreground));
    line-height: 1.5;
  }

  .listing-sidebar-filters {
    padding: 12px 0;
    border-top: 1px solid hsl(var(--border));
  }

  .listing-sidebar-bottom {
    margin-top: auto;
  }

  .listing-sidebar-rule {
    border: none;
    border-top: 1px solid hsl(var(--border));
    margin: 0 0 10px 0;
  }

  @media (max-width: 900px) {
    .listing-sidebar {
      display: none;
    }
  }
</style>
